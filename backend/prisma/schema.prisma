// Quiztroyer - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Challenge {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  pin       String
  branding  Json     @default("{}")
  // branding: { bgColor, logoUrl, headerText, footerText, primaryColor, accentColor }
  status    ChallengeStatus @default(DRAFT)
  questions Question[]
  sessions  GameSession[]
  liveRoom  LiveRoom?
  runNumber Int      @default(1)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Question {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  order       Int
  type        QuestionType
  prompt      String
  maxChars    Int       @default(200)
  timeLimit   Int       @default(30)
  // config JSON shape by type:
  // quiz:       { options: [{id, text, isCorrect}] }
  // truefalse:  { correctAnswer: boolean }
  // puzzle:     { items: [string] }  <- stored in CORRECT order
  // pinimage:   { imageUrl: string, correctX: number, correctY: number, radius: number }
  config      Json
  answers     Answer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([challengeId, order])
}

model GameSession {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  playerName  String
  playerDni   String
  playerEmail String?
  playerPhone String?
  runNumber   Int       @default(1)
  socketId    String?
  totalScore  Int       @default(0)
  answers     Answer[]
  rank        Int?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([challengeId, playerDni, runNumber])
  @@index([challengeId, totalScore])
}

model Answer {
  id         String      @id @default(cuid())
  sessionId  String
  session    GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   Question    @relation(fields: [questionId], references: [id])
  // answer JSON shape by type:
  // quiz:       { optionId: string }
  // truefalse:  { value: boolean }
  // puzzle:     { order: [string] }
  // pinimage:   { x: number, y: number }
  answer     Json
  correct    Boolean
  score      Int         @default(0)
  timeTakenMs Int        @default(0)
  createdAt  DateTime    @default(now())

  @@unique([sessionId, questionId])
}

model LiveRoom {
  id             String    @id @default(cuid())
  challengeId    String    @unique
  challenge      Challenge @relation(fields: [challengeId], references: [id])
  currentSlide   Int       @default(-1)
  slideStartedAt DateTime?
  phase          RoomPhase @default(LOBBY)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum ChallengeStatus {
  DRAFT
  LIVE
  ENDED
}

enum QuestionType {
  QUIZ
  TRUEFALSE
  PUZZLE
  PINIMAGE
}

enum RoomPhase {
  LOBBY
  PLAYING
  RANKING
  ENDED
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Raffle {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  pin       String
  status    RaffleStatus  @default(DRAFT)
  branding  Json          @default("{}")
  entries   RaffleEntry[]
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([slug])
}

model RaffleEntry {
  id        String   @id @default(cuid())
  raffleId  String
  raffle    Raffle   @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  nombre    String
  apellido  String
  dni       String
  correo    String
  telefono  String
  socketId  String?
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([raffleId, dni])
  @@unique([raffleId, correo])
  @@unique([raffleId, telefono])
  @@index([raffleId])
}

enum RaffleStatus {
  DRAFT
  OPEN
  SPINNING
  DONE
}

// ─── Módulo de Concurso Externo ("El Gran Upgrade") ─────────────────────────

enum Procesador {
  INTEL_I3_10A_14A
  INTEL_I5_10A_14A
  INTEL_I7_10A_14A
  INTEL_I9_10A_14A
  AMD_RYZEN_3
  AMD_RYZEN_5
  AMD_RYZEN_7
  AMD_RYZEN_9
  OTRO
}

enum GraficaActual {
  GTX_10_SERIES
  GTX_16_SERIES
  RTX_20_SERIES
  RTX_30_SERIES
  RTX_40_SERIES
  AMD_RX_5000
  AMD_RX_6000
  AMD_RX_7000
  INTEL_ARC
  GPU_INTEGRADA
  OTRA
}

enum FuentePoderWatts {
  MENOS_500W
  W500_649
  W650_749
  W750_849
  W850_999
  MAS_1000W
  NO_SE
}

model ContestLead {
  id               String           @id @default(cuid())
  nombre           String
  email            String           @unique
  telefono         String
  procesador       Procesador
  graficaActual    GraficaActual
  fuentePoderWatts FuentePoderWatts
  fotoExteriorUrl  String
  fotoInteriorUrl  String
  historia         String
  aceptaTyC        Boolean
  aceptaMarketing  Boolean
  isFinalist       Boolean          @default(false)
  voteCount        Int              @default(0)
  votes            ContestVote[]
  createdAt        DateTime         @default(now())

  @@index([isFinalist])
  @@index([procesador])
  @@index([graficaActual])
  @@index([fuentePoderWatts])
}

model ContestVote {
  id        String      @id @default(cuid())
  entryId   String
  entry     ContestLead @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voterIp   String
  createdAt DateTime    @default(now())

  @@unique([voterIp])
}

